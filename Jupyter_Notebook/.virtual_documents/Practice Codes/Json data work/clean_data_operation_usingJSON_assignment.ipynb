def recomend(data):
    recomend_user = []
    
    for user in data:
        # 1. Create a fresh dictionary INSIDE the loop for each person
        recomend_name = {} 
        
        if(float(user["rating"]) <= 4):
            recomend_name["name"] = user["name"]
            recomend_name["brand"] = "Apple"
        else:
            recomend_name["name"] = user["name"]
            recomend_name["brand"] = "samsung"
            
        # 2. Un-indent this so it runs for EVERY user, not just the 'else' group
        recomend_user.append(recomend_name)
        
    # 3. Return the complete list, not the temporary dictionary
    return recomend_user


recomend(data)



